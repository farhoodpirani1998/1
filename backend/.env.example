DATABASE_URL=postgres://user:password@localhost:5432/school_tuition

# Sprint 3 Phase 2 — reliability hardening: max Postgres connections this
# app instance's pool may open (see `extra.max` in app.module.ts). Leave
# unset to default to 10, matching pg's own default. Adjust down when
# running multiple replicas behind a load balancer so the combined pools
# across all instances stay under Postgres's own max_connections limit,
# or up for a single instance under heavier concurrent load.
DB_POOL_MAX=10
JWT_SECRET=change-this-to-a-long-random-string
REDIS_HOST=localhost
REDIS_PORT=6379
# Required in production (enforced by src/config/env.validation.ts) and by
# docker-compose.yml's redis service (--requirepass). Leave unset for local
# dev against an unauthenticated Redis; set a strong unique value in
# production -- Redis has no ACL/auth by default.
REDIS_PASSWORD=
PORT=3000
NODE_ENV=development

# Structured logger level (pino). One of: fatal, error, warn, info, debug,
# trace. Defaults to "info" in production, "debug" otherwise.
LOG_LEVEL=

# SMS gateway (any REST provider that accepts {sender, receptor, message})
# Leave unset during local dev — SmsProviderService logs instead of sending.
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_NUMBER=

# Sprint 3 Phase 2 — reliability hardening: milliseconds SmsProviderService
# waits for the gateway before aborting the request. Leave unset to
# default to 10000 (10s). Unrelated to whether SMS is configured at all
# (SMS_API_URL/SMS_API_KEY above are what gate that).
SMS_REQUEST_TIMEOUT_MS=10000

# Comma-separated list of allowed frontend origins (production). Leave unset
# in dev to allow all origins.
CORS_ORIGINS=

# Swagger/OpenAPI UI + JSON document at GET /api/v1/docs (and /docs-json).
# Only the literal string "true" enables it, in any environment — unset or
# any other value = disabled. See docs/deployment/DEPLOYMENT.md for the
# production recommendation before turning this on outside local dev.
ENABLE_SWAGGER=

# Sentry error reporting. Both optional — leave SENTRY_DSN unset to
# disable Sentry entirely (the app boots and runs normally either way).
# SENTRY_ENVIRONMENT tags reported errors (e.g. "production", "staging");
# falls back to NODE_ENV, then "development", if unset. See
# docs/deployment/DEPLOYMENT.md for local vs. production behavior.
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# Sprint 2 — Feature 1: selects the StorageProvider implementation (see
# common/storage/storage.module.ts). Only "local" is supported today --
# any other value fails loudly at boot. Leave unset to default to "local".
STORAGE_DRIVER=local

# Sprint 3 Phase 1 — reliability hardening: threshold in milliseconds
# above which TypeORM logs a query as slow (see maxQueryExecutionTime in
# app.module.ts). Leave unset to default to 1000ms.
DB_SLOW_QUERY_THRESHOLD_MS=1000

# Sprint P1 — Universal Avatar System. Directory avatar image files are
# written to and served from (see common/storage/avatar-storage.service.ts
# and main.ts's static route). Relative paths resolve against the
# process's working directory. Leave unset to default to
# "uploads/avatars". If deploying via docker-compose.yml, this should
# point at the mounted "avatar-uploads" volume so files survive
# container restarts/redeploys.
AVATAR_UPLOAD_DIR=

# Sprint 2 — Feature 2B: account-level login lockout (independent of the
# per-IP throttle on /auth/login). Leave unset to use the defaults baked
# into auth.service.ts: 5 consecutive bad-password attempts locks the
# account for 15 minutes.
LOGIN_LOCKOUT_THRESHOLD=
LOGIN_LOCKOUT_DURATION_MINUTES=

# Required by `npm run seed` to create the first super_admin account.
# No default/fallback exists in code — the seed script fails loudly if
# either of these is missing. Set a real phone number and a strong,
# unique password before running the seed script; do not commit real
# values here.
SEED_ADMIN_PHONE=
SEED_ADMIN_PASSWORD=

# Backup & restore (scripts/backup.sh, scripts/restore.sh). Only
# DATABASE_URL (already required above) is mandatory — everything below is
# optional with sane defaults. See docs/deployment/BACKUP_RESTORE.md.
# Leave BACKUP_DIR/BACKUP_RETENTION_DAYS unset to use the defaults
# (./backups, 14 days). Leave all S3_* unset for a local-only backup — S3
# upload is fully optional and off by default.
BACKUP_DIR=
BACKUP_RETENTION_DAYS=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Production requirements (enforced at boot by src/config/env.validation.ts) ---
# When NODE_ENV=production, the app refuses to start unless CORS_ORIGINS and
# REDIS_HOST are explicitly set (no silent "allow all" / "localhost"
# fallback) and JWT_SECRET is at least 32 characters long. DATABASE_URL and
# JWT_SECRET are required in every environment.
#
# If deploying via the provided docker-compose.yml, DATABASE_URL and
# REDIS_HOST must point at the compose service names, not localhost, e.g.
#   DATABASE_URL=postgres://postgres:<password>@postgres:5432/school_tuition
#   REDIS_HOST=redis
# docker-compose.yml also requires POSTGRES_PASSWORD (and optionally
# POSTGRES_USER/POSTGRES_DB) to configure the postgres container itself,
# and REDIS_PASSWORD to configure the redis container's --requirepass.

