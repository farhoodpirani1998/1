DATABASE_URL=postgres://user:password@localhost:5432/school_tuition
JWT_SECRET=change-this-to-a-long-random-string
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=3000
NODE_ENV=development

# SMS gateway (any REST provider that accepts {sender, receptor, message})
# Leave unset during local dev — SmsProviderService logs instead of sending.
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_NUMBER=

# Comma-separated list of allowed frontend origins (production). Leave unset
# in dev to allow all origins.
CORS_ORIGINS=

# Used once by `npm run seed` to create the first super_admin account.
SEED_ADMIN_PHONE=09120000000
SEED_ADMIN_PASSWORD=ChangeMe123!
